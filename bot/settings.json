{
  "tesseract_path": "C:\\Program Files\\Tesseract-OCR\\tesseract.exe",

  "capture_regions": {
    "loading_strip": {
      "left": 35,
      "top": 850,
      "width": 620,
      "height": 120
    },
    "tab_map_name": {
      "left": 700,
      "top": 875,
      "width": 520,
      "height": 40
    }
  },

  "preprocess": {
    "loading_strip": {
      "scale": 4,
      "threshold": 185
    },
    "tab_map_name": {
      "scale": 4,
      "threshold": 185
    }
  },

  "matching": {
    "min_confidence": 80,
    "min_text_length": 8,
    "required_confirmations": 2
  },

  "automation": {
    "idle_poll_ms": 700,
    "loading_ocr_poll_ms": 200,
    "loading_arm_timeout_ms": 20000,
    "loading_post_bar_grace_ms": 3500,
    "post_detect_cooldown_ms": 2000
  },

  "black_bar": {
    "sample_points": [
      [20, 8],
      [80, 8],
      [140, 8],
      [200, 8],
      [260, 8],
      [320, 8]
    ],
    "brightness_threshold": 32,
    "required_dark_points": 5,
    "enter_streak": 2,
    "leave_streak": 2
  },

  "server": {
    "host": "127.0.0.1",
    "port": 8765
  },

  "paths": {
    "output_json": "../output/current_map.json",
    "overlay_dir": "../overlay",
    "maps_dir": "../assets/maps",
    "debug_dir": "../output/debug"
  },

  "debug": {
    "enabled": true,
    "save_debug_images": true,
    "max_history": 15
  },

  "input": {
    "manual_hotkey": "F8"
  },
  "publish": {
    "enabled": true,
    "api_base_url": "https://dbdmap-api.sic4riodragon.uk",
    "update_token": ""
  }
}